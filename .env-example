# Provedor LLM: openai | anthropic | groq | gemini | ollama
LLM_PROVIDER=ollama
# Fallbacks opcionais, em ordem, caso o provider primário falhe
LLM_FALLBACK_PROVIDERS=groq,gemini

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (modelos locais — não requer chave)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Gemini
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-2.0-flash

# Caminho para o artefato do modelo
MODEL_PATH=models/pcos_model.joblib
